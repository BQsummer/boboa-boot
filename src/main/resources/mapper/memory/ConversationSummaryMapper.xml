<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bqsummer.mapper.memory.ConversationSummaryMapper">

    <resultMap id="BaseResultMap" type="com.bqsummer.common.dto.memory.ConversationSummary">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="ai_character_id" property="aiCharacterId"/>
        <result column="session_id" property="sessionId"/>
        <result column="summary_json" property="summaryJson"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="covered_until_message_id" property="coveredUntilMessageId"/>
        <result column="message_count" property="messageCount"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 获取最新的总结 -->
    <select id="findLatestSummaries" resultMap="BaseResultMap">
        SELECT id, user_id, ai_character_id, session_id, summary_json,
               covered_until_message_id, message_count, created_at
        FROM conversation_summary
        WHERE user_id = #{userId}
          AND ai_character_id = #{aiCharacterId}
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

    <!-- 获取最新一条总结 -->
    <select id="findLatestSummary" resultMap="BaseResultMap">
        SELECT id, user_id, ai_character_id, session_id, summary_json,
               covered_until_message_id, message_count, created_at
        FROM conversation_summary
        WHERE user_id = #{userId}
          AND ai_character_id = #{aiCharacterId}
        ORDER BY created_at DESC
        LIMIT 1
    </select>

</mapper>
